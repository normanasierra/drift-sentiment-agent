# Copy this file to .env and fill in your secrets. NEVER commit .env.
# Market data (Massive = Polygon rebranded; same host/endpoints). The app prefers
# MASSIVE_API_KEY if set, else POLYGON_API_KEY.
MASSIVE_API_KEY=your_massive_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# --- Daily brief delivery (scripts/daily_brief) ---
# Gmail SMTP: use a 16-char App Password, NOT your account password.
# Generate at https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
BRIEF_EMAIL_TO=you@gmail.com

# CallMeBot WhatsApp (see scripts/daily_brief/README.md for the 1-time setup)
CALLMEBOT_PHONE=+59171234567
CALLMEBOT_APIKEY=your_callmebot_apikey

# --- Real-data sources for the brief (all OPTIONAL; each degrades gracefully) ---
# Yahoo quotes need no key. These add your live positions to the brief:
# Hyperliquid (perps DEX) — your public wallet address, read-only, no key needed.
HYPERLIQUID_ADDRESS=0xyour_wallet_address
# Schwab / thinkorswim positions — a bearer token from the Schwab Trader API
# OAuth flow (developer app + one-time consent). See data_sources/schwab.py.
SCHWAB_ACCESS_TOKEN=your_schwab_bearer_token
