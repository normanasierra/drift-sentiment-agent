# Copy this file to .env and fill in your keys.

# --- Market data ---
POLYGON_API_KEY=your_polygon_api_key_here

# --- Email delivery (SMTP). For Gmail, SMTP_PASSWORD is an App Password,
#     NOT your normal password: https://myaccount.google.com/apppasswords ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=normanasierra@gmail.com

# --- WhatsApp delivery (Twilio). Sandbox works for testing; join it first.
#     https://console.twilio.com/ -> Messaging -> Try it out -> WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1787XXXXXXX

# --- Extra data sources (all optional; each degrades gracefully) ---

# News step (Claude + web search). Without it the report still sends, no news.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Read market newsletters (MarketSnacks / Barron's / CNBC / Yahoo) from Gmail via
# IMAP. Reuse the same Gmail App Password as SMTP if it's the same account.
IMAP_HOST=imap.gmail.com
IMAP_USER=youraddress@gmail.com
IMAP_PASSWORD=your_16_char_app_password

# Hyperliquid (perps) — read-only, just your PUBLIC wallet address.
HYPERLIQUID_ADDRESS=0xYourPublicWalletAddress

# ThinkorSwim / Schwab — Schwab Trader API (OAuth2). Register an app at
# developer.schwab.com, complete the one-time consent, then paste a bearer token.
SCHWAB_ACCESS_TOKEN=
