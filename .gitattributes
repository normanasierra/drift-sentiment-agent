# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST stay LF — a CRLF shebang breaks on macOS/Linux
# ("bad interpreter: /bin/bash^M"). The Mac launchers depend on this.
*.sh       text eol=lf
*.command  text eol=lf

# Windows-only launchers keep CRLF (wscript/cmd/PowerShell are happy either way,
# but this avoids churn when editing them on the PC).
*.vbs      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf
